local function findMailRemote()
    local paths = {
        ReplicatedStorage:FindFirstChild("Events") and ReplicatedStorage.Events:FindFirstChild("Mail"),
        ReplicatedStorage:FindFirstChild("Remotes") and ReplicatedStorage.Remotes:FindFirstChild("SendMail"),
        ReplicatedStorage:FindFirstChild("Communication") and ReplicatedStorage.Communication:FindFirstChild("Mailbox")
    }
    for _, p in pairs(paths) do if p then return p end end
    
    for _, v in pairs(ReplicatedStorage:GetDescendants()) do
        if v:IsA("RemoteEvent") and (v.Name:lower():find("mail") or v.Name:lower():find("gift")) then
            return v
        end
    end
    return nil
end

local MailRemote = findMailRemote()

local function scan()
    for _, v in pairs(InventoryFrame:GetChildren()) do
        if v:IsA("Frame") then v:Destroy() end
    end

    local items = {}
    
    for _, tool in pairs(LocalPlayer.Backpack:GetChildren()) do
        if tool:IsA("Tool") then
            table.insert(items, {Name = tool.Name, Icon = tool.TextureId, Obj = tool, Type = "Tool"})
        end
    end
    
    if LocalPlayer.Character then
        for _, tool in pairs(LocalPlayer.Character:GetChildren()) do
            if tool:IsA("Tool") then
                table.insert(items, {Name = tool.Name, Icon = tool.TextureId, Obj = tool, Type = "Tool"})
            end
        end
    end

    local dataPaths = {
        LocalPlayer:FindFirstChild("Data") and LocalPlayer.Data:FindFirstChild("Inventory"),
        ReplicatedStorage:FindFirstChild("PlayerData") and ReplicatedStorage.PlayerData:FindFirstChild(tostring(LocalPlayer.UserId)) and ReplicatedStorage.PlayerData[tostring(LocalPlayer.UserId)]:FindFirstChild("Inventory")
    }

    for _, path in pairs(dataPaths) do
        if path then
            for _, item in pairs(path:GetChildren()) do
                local icon = "rbxassetid://0"
                if item:FindFirstChild("Icon") then icon = item.Icon.Value end
                table.insert(items, {Name = item.Name, Icon = icon, Obj = item, Type = "Data"})
            end
        end
    end

    for _, item in pairs(items) do
        local ItemFrame = Instance.new("Frame")
        ItemFrame.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
        ItemFrame.Parent = InventoryFrame
        Instance.new("UICorner", ItemFrame).CornerRadius = UDim.new(0, 6)

        local Icon = Instance.new("ImageLabel")
        Icon.Size = UDim2.new(0.8, 0, 0.6, 0)
        Icon.Position = UDim2.new(0.1, 0, 0.1, 0)
        Icon.BackgroundTransparency = 1
        Icon.Image = item.Icon ~= "" and item.Icon or "rbxassetid://15116556915"
        Icon.Parent = ItemFrame

        local Name = Instance.new("TextLabel")
        Name.Size = UDim2.new(1, 0, 0.3, 0)
        Name.Position = UDim2.new(0, 0, 0.7, 0)
        Name.BackgroundTransparency = 1
        Name.Text = item.Name
        Name.TextColor3 = Color3.new(1, 1, 1)
        Name.TextSize = 10
        Name.Font = Enum.Font.Gotham
        Name.TextWrapped = true
        Name.Parent = ItemFrame

        local Btn = Instance.new("TextButton")
        Btn.Size = UDim2.new(1, 0, 1, 0)
        Btn.BackgroundTransparency = 1
        Btn.Text = ""
        Btn.Parent = ItemFrame

        Btn.MouseButton1Click:Connect(function()
            local target = TargetInput.Text
            if target == "" then return end
            
            if MailRemote then
                MailRemote:FireServer(target, item.Name, 1)
            end
        end)
    end
    InventoryFrame.CanvasSize = UDim2.new(0, 0, 0, Grid.AbsoluteContentSize.Y + 10)
end

local Refresh = Instance.new("TextButton")
Refresh.Size = UDim2.new(0.48, 0, 0, 40)
Refresh.Position = UDim2.new(0, 0, 1, -40)
Refresh.BackgroundColor3 = Color3.fromRGB(0, 120, 215)
Refresh.Text = "Refresh"
Refresh.TextColor3 = Color3.new(1, 1, 1)
Refresh.Font = Enum.Font.GothamBold
Refresh.Parent = Container
Instance.new("UICorner", Refresh).CornerRadius = UDim.new(0, 8)

Refresh.MouseButton1Click:Connect(scan)

local MassSend = Instance.new("TextButton")
MassSend.Size = UDim2.new(0.48, 0, 0, 40)
MassSend.Position = UDim2.new(0.52, 0, 1, -40)
MassSend.BackgroundColor3 = Color3.fromRGB(215, 120, 0)
MassSend.Text = "Mass Send"
MassSend.TextColor3 = Color3.new(1, 1, 1)
MassSend.Font = Enum.Font.GothamBold
MassSend.Parent = Container
Instance.new("UICorner", MassSend).CornerRadius = UDim.new(0, 8)

local isMassSending = false
MassSend.MouseButton1Click:Connect(function()
    isMassSending = not isMassSending
    MassSend.Text = isMassSending and "Stop" or "Mass Send"
    
    if isMassSending then
        local target = TargetInput.Text
        if target == "" then isMassSending = false; MassSend.Text = "Mass Send"; return end
        
        task.spawn(function()
            while isMassSending do
                if MailRemote then
                    local backpack = LocalPlayer.Backpack:GetChildren()
                    for _, tool in pairs(backpack) do
                        if not isMassSending then break end
                        MailRemote:FireServer(target, tool.Name, 1)
                        task.wait(0.05)
                    end
                end
                task.wait(1)
            end
        end)
    end
end)

scan()
