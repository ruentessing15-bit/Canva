local function findMailRemote()
    local possibleRemotes = {}
    for _, v in pairs(ReplicatedStorage:GetDescendants()) do
        if v:IsA("RemoteEvent") then
            local lowerName = v.Name:lower()
            if lowerName:find("mail") or lowerName:find("gift") or lowerName:find("senditem") or lowerName:find("trade") then
                table.insert(possibleRemotes, v)
            end
        end
    end
    
    for _, remote in pairs(possibleRemotes) do
        if remote.Name == "SendMail" or remote.Name == "MailboxRemote" or remote.Name == "GiftItem" then
            return remote
        end
    end
    
    if #possibleRemotes > 0 then
        return possibleRemotes[1]
    end
    
    return nil
end

local MailRemote = findMailRemote()

local function scan()
    for _, v in pairs(InventoryFrame:GetChildren()) do
        if v:IsA("Frame") then v:Destroy() end
    end

    local items = {}
    
    for _, tool in pairs(LocalPlayer.Backpack:GetChildren()) do
        if tool:IsA("Tool") then
            table.insert(items, {Name = tool.Name, Icon = tool.TextureId, Obj = tool, Type = "Tool"})
        end
    end
    
    if LocalPlayer.Character then
        for _, tool in pairs(LocalPlayer.Character:GetChildren()) do
            if tool:IsA("Tool") then
                table.insert(items, {Name = tool.Name, Icon = tool.TextureId, Obj = tool, Type = "Tool"})
            end
        end
    end

    local function findItemsInFolder(folder)
        if folder then
            for _, itemInstance in pairs(folder:GetChildren()) do
                if itemInstance:IsA("Folder") or itemInstance:IsA("Configuration") or itemInstance:IsA("Model") or itemInstance:IsA("Part") or itemInstance:IsA("StringValue") or itemInstance:IsA("NumberValue") then
                    local itemName = itemInstance.Name
                    local itemIcon = "rbxassetid://0"
                    
                    if itemInstance:FindFirstChild("Icon") and itemInstance.Icon:IsA("StringValue") then
                        itemIcon = itemInstance.Icon.Value
                    elseif itemInstance:FindFirstChild("TextureId") and itemInstance.TextureId:IsA("StringValue") then
                        itemIcon = itemInstance.TextureId.Value
                    end
                    
                    if itemInstance:IsA("StringValue") or itemInstance:IsA("NumberValue") then
                        itemName = itemInstance.Name .. " (" .. tostring(itemInstance.Value) .. ")"
                    end

                    table.insert(items, {Name = itemName, Icon = itemIcon, Obj = itemInstance, Type = "Data"})
                end
            end
        end
    end

    findItemsInFolder(LocalPlayer:FindFirstChild("Data") and LocalPlayer.Data:FindFirstChild("Inventory"))
    if ReplicatedStorage:FindFirstChild("PlayerData") and ReplicatedStorage.PlayerData:FindFirstChild(tostring(LocalPlayer.UserId)) then
        findItemsInFolder(ReplicatedStorage.PlayerData[tostring(LocalPlayer.UserId)]:FindFirstChild("Inventory"))
    end
    
    for _, item in pairs(items) do
        local ItemFrame = Instance.new("Frame")
        ItemFrame.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
        ItemFrame.Parent = InventoryFrame
        Instance.new("UICorner", ItemFrame).CornerRadius = UDim.new(0, 6)

        local Icon = Instance.new("ImageLabel")
        Icon.Size = UDim2.new(0.8, 0, 0.6, 0)
        Icon.Position = UDim2.new(0.1, 0, 0.1, 0)
        Icon.BackgroundTransparency = 1
        Icon.Image = item.Icon ~= "" and item.Icon or "rbxassetid://15116556915"
        Icon.Parent = ItemFrame

        local Name = Instance.new("TextLabel")
        Name.Size = UDim2.new(1, 0, 0.3, 0)
        Name.Position = UDim2.new(0, 0, 0.7, 0)
        Name.BackgroundTransparency = 1
        Name.Text = item.Name
        Name.TextColor3 = Color3.new(1, 1, 1)
        Name.TextSize = 10
        Name.Font = Enum.Font.Gotham
        Name.TextWrapped = true
        Name.Parent = ItemFrame

        local Btn = Instance.new("TextButton")
        Btn.Size = UDim2.new(1, 0, 1, 0)
        Btn.BackgroundTransparency = 1
        Btn.Text = ""
        Btn.Parent = ItemFrame

        Btn.MouseButton1Click:Connect(function()
            local target = TargetInput.Text
            local amount = tonumber(AmountInput.Text) or 1
            if target == "" or amount <= 0 then return end
            
            if MailRemote then
                MailRemote:FireServer(target, item.Name, amount)
            end
        end)
    end
    InventoryFrame.CanvasSize = UDim2.new(0, 0, 0, Grid.AbsoluteContentSize.Y + 10)
end

local Refresh = Instance.new("TextButton")
Refresh.Size = UDim2.new(0.48, 0, 0, 35)
Refresh.Position = UDim2.new(0, 0, 1, -35)
Refresh.BackgroundColor3 = Color3.fromRGB(0, 120, 215)
