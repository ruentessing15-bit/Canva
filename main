Refresh.Parent = Container
Instance.new("UICorner", Refresh).CornerRadius = UDim.new(0, 6)

Refresh.MouseButton1Click:Connect(scan)

local MassSend = Instance.new("TextButton")
MassSend.Size = UDim2.new(0.48, 0, 0, 35)
MassSend.Position = UDim2.new(0.52, 0, 1, -35)
MassSend.BackgroundColor3 = Color3.fromRGB(215, 120, 0)
MassSend.Text = "Mass Send"
MassSend.TextColor3 = Color3.new(1, 1, 1)
MassSend.Font = Enum.Font.GothamBold
MassSend.Parent = Container
Instance.new("UICorner", MassSend).CornerRadius = UDim.new(0, 6)

local isMassSending = false
MassSend.MouseButton1Click:Connect(function()
    isMassSending = not isMassSending
    MassSend.Text = isMassSending and "Stop" or "Mass Send"
    
    if isMassSending then
        local target = TargetInput.Text
        local amount = tonumber(AmountInput.Text) or 1
        if target == "" or amount <= 0 then isMassSending = false; MassSend.Text = "Mass Send"; return end
        
        task.spawn(function()
            while isMassSending do
                if MailRemote then
                    local currentItems = {}
                    for _, tool in pairs(LocalPlayer.Backpack:GetChildren()) do
                        if tool:IsA("Tool") then table.insert(currentItems, {Name = tool.Name, Obj = tool}) end
                    end
                    if LocalPlayer.Character then
                        for _, tool in pairs(LocalPlayer.Character:GetChildren()) do
                            if tool:IsA("Tool") then table.insert(currentItems, {Name = tool.Name, Obj = tool}) end
                        end
                    end

                    for _, itemData in pairs(currentItems) do
                        if not isMassSending then break end
                        MailRemote:FireServer(target, itemData.Name, amount)
                        task.wait(0.05)
                    end
                else
                    warn("Error: Mail Remote not found for mass send.")
                end
                task.wait(1)
            end
        end)
    end
end)

scan()
